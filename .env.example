# Database (RDS on AWS, or Neon for local dev)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Telegram bots
TELEGRAM_BOT_TOKEN_CS=token_del_bot_cliente
TELEGRAM_BOT_TOKEN_AM=token_del_bot_admin
WEBHOOK_BASE_URL=http://your-alb-dns.us-east-1.elb.amazonaws.com
WEBHOOK_SECRET_TOKEN=tu_token_secreto_para_validar_webhooks

# NVIDIA NIM (free at build.nvidia.com)
NVIDIA_API_KEY=nvapi-...
NVIDIA_MODEL_PRIMARY=meta/llama-3.3-70b-instruct
NVIDIA_MODEL_FALLBACK=mistralai/mistral-large-2-instruct

# Background scheduler (false on AWS — use EventBridge; true for local dev)
ENABLE_BACKGROUND_SCHEDULER=false

# Redis / Upstash (session memory + idempotency)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=tu_token_rest_de_upstash
REDIS_MEMORY_ENABLED=true
REDIS_MEMORY_TTL_CUSTOMER_MINUTES=360
REDIS_MEMORY_TTL_ADMIN_MINUTES=30
REDIS_IDEMPOTENCY_TTL_MINUTES=30
REDIS_HISTORY_MAX_MESSAGES=24
